# Database
# WICHTIG: POSTGRES_PASSWORD gilt nur beim ERSTEN Start (leeres Volume).
# Steht in den Logs "Skipping initialization", ändert .env das Passwort NICHT.
# Lösung: scripts/reset-db.sh  oder  docker compose down -v
POSTGRES_USER=promptdb
POSTGRES_PASSWORD=promptdb-dev-secret
POSTGRES_DB=promptdb

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ALLOW_REGISTRATION=true
CORS_ORIGINS=http://localhost,https://localhost,http://localhost:5173
ENVIRONMENT=development
# ENVIRONMENT=production  → erfordert starkes SECRET_KEY (≥32 Zeichen) und CORS_ORIGINS
TRUST_PROXY_HEADERS=true

# Frontend ports (docker compose host mapping)
HTTP_PORT=80
HTTPS_PORT=443
SSL_CERT_DIR=./certs

# Docker Compose: API über nginx-Proxy (Same-Origin, kein CORS nötig)
VITE_API_URL=
API_UPSTREAM=http://backend:8000

# Nur für getrennte API-Domain (Kubernetes / GitHub Release-Build):
# VITE_API_URL=https://api.prompt-db.example.com
# API_UPSTREAM=

# Production example:
# ENVIRONMENT=production
# ALLOW_REGISTRATION=true
# TRUST_PROXY_HEADERS=true
# SECRET_KEY=<output of: openssl rand -hex 32>
# CORS_ORIGINS=https://prompt-db.example.com

# Container images (production)
IMAGE_REGISTRY=ghcr.io/erlkoenig91
TAG=latest

# Lokale Frontend-Entwicklung (npm run dev)
# VITE_API_URL=http://localhost:8000
